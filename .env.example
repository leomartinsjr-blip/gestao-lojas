# ── Microvix Integration ──────────────────────────────────────────────────
# Credenciais da API Microvix (WebService SOAP)
MICROVIX_CNPJ=XX.XXX.XXX/XXXX-XX
MICROVIX_CNPJ_REDE=XX.XXX.XXX/XXXX-XX   # normalmente igual ao MICROVIX_CNPJ
MICROVIX_USUARIO=seu_usuario
MICROVIX_SENHA=sua_senha

# Intervalo de sync automático em minutos (padrão: 20)
MICROVIX_INTERVAL_MIN=20

# Mapeamento: código PORTAL do Microvix → nome do board no sistema
# Execute POST /api/microvix/raw para ver o campo PORTAL retornado pela API
MICROVIX_STORE_MAP={"1":"delrey","2":"minas","3":"contagem","4":"estacao","5":"tommy","6":"lez"}

# ── Nomes dos campos (ajuste se a API retornar nomes diferentes) ───────────
# Veja os nomes exatos executando POST /api/microvix/raw
MX_FIELD_STORE=PORTAL
MX_FIELD_VEND_NAME=NOME_VENDEDOR
MX_FIELD_DATE=DT_MOVIMENTO
MX_FIELD_VALUE=VL_VENDA
MX_FIELD_PECAS=QTD_PECAS
MX_FIELD_ATEND=QTD_ATENDIMENTOS

# ── Servidor ───────────────────────────────────────────────────────────────
PORT=3000
MONGODB_URI=sua_connection_string_mongodb
APP_URL=https://gestao-lojas.onrender.com

# ── CRM / WhatsApp (Z-API) ────────────────────────────────────────────────
# Crie uma instância em app.z-api.io e copie os dados abaixo
ZAPI_INSTANCE_ID=seu-instance-id
ZAPI_TOKEN=seu-token
ZAPI_CLIENT_TOKEN=seu-client-token

# Board de referência para sync de clientes CRM (cadastro único da rede).
# Use o nome de uma das lojas que compartilham o mesmo cadastro (ex: delrey).
# Se não configurado, usa a primeira loja de MICROVIX_LOJAS.
MICROVIX_CRM_BOARD=delrey

# ── Email (recuperação de senha) ───────────────────────────────────────────
# Use uma Senha de App do Gmail (myaccount.google.com → Segurança → Senhas de app)
EMAIL_USER=seuemail@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
